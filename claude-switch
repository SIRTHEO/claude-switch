#!/usr/bin/env zsh
# claude-switch — Claude Code multi-account wrapper
# Instant account switching by swapping oauthAccount in ~/.claude.json

set -uo pipefail

ACCOUNTS_DIR="$HOME/.claude/accounts"
CLAUDE_JSON="$HOME/.claude.json"

# --- Find the real claude binary ---
find_real_claude() {
  if [[ -n "${CLAUDE_SWITCH_BIN:-}" ]]; then
    echo "$CLAUDE_SWITCH_BIN"
    return
  fi

  # Resolve this script's real path (works with symlinks)
  local self_path="${0:A}"

  for dir in ${(s/:/)PATH}; do
    local candidate="$dir/claude"
    [[ -x "$candidate" ]] || continue
    # Skip if candidate resolves to this script
    [[ "${candidate:A}" != "$self_path" ]] || continue
    # Skip if candidate is a shell script (we want the real binary)
    if file -b "$candidate" 2>/dev/null | grep -q 'Mach-O\|ELF'; then
      echo "$candidate"
      return
    fi
  done

  echo "Error: could not find the real claude binary in PATH." >&2
  exit 1
}

CLAUDE_BIN="$(find_real_claude)"

# --- Helpers ---
get_current_email() {
  python3 -c "
import json
try:
    with open('$CLAUDE_JSON') as f:
        print(json.load(f).get('oauthAccount', {}).get('emailAddress', ''))
except:
    pass
" 2>/dev/null
}

save_account() {
  local email="$1"
  mkdir -p "$ACCOUNTS_DIR"
  chmod 700 "$ACCOUNTS_DIR"
  python3 -c "
import json
with open('$CLAUDE_JSON') as f:
    d = json.load(f)
with open('$ACCOUNTS_DIR/$email.json', 'w') as f:
    json.dump(d.get('oauthAccount', {}), f, indent=2)
" 2>/dev/null
  chmod 600 "$ACCOUNTS_DIR/$email.json"
}

load_account() {
  local email="$1"
  local account_file="$ACCOUNTS_DIR/$email.json"

  if [[ ! -f "$account_file" ]]; then
    echo "Error: no saved account for $email" >&2
    return 1
  fi

  python3 << PYEOF
import json
with open('$CLAUDE_JSON') as f:
    d = json.load(f)
with open('$account_file') as f:
    d['oauthAccount'] = json.load(f)
with open('$CLAUDE_JSON', 'w') as f:
    json.dump(d, f, separators=(',', ':'))
PYEOF
}

list_accounts() {
  local current_email
  current_email="$(get_current_email)"

  local has_accounts=false
  for f in "$ACCOUNTS_DIR"/*.json(N); do
    has_accounts=true
    break
  done

  if [[ "$has_accounts" == "false" ]]; then
    echo "No saved accounts. Run: claude switch add"
    return
  fi

  echo "Saved accounts:"
  echo ""
  for f in "$ACCOUNTS_DIR"/*.json(N); do
    local email="${${f:t}%.json}"
    if [[ "$email" == "$current_email" ]]; then
      echo "  * $email (active)"
    else
      echo "    $email"
    fi
  done
}

switch_to() {
  local target_email="$1"
  local current_email
  current_email="$(get_current_email)"

  if [[ "$target_email" == "$current_email" ]]; then
    echo "Already on $target_email"
    return 0
  fi

  if [[ -n "$current_email" ]]; then
    save_account "$current_email"
  fi

  load_account "$target_email"
  echo "Switched to $target_email"
}

switch_interactive() {
  local current_email
  current_email="$(get_current_email)"

  local accounts=()
  for f in "$ACCOUNTS_DIR"/*.json(N); do
    accounts+=("${${f:t}%.json}")
  done

  if [[ ${#accounts[@]} -eq 0 ]]; then
    echo "No saved accounts. Run: claude switch add"
    return 1
  fi

  if [[ ${#accounts[@]} -lt 2 ]]; then
    echo "Only one account saved. Run: claude switch add"
    return 1
  fi

  echo "Accounts:"
  echo ""
  local i=1
  for email in "${accounts[@]}"; do
    if [[ "$email" == "$current_email" ]]; then
      echo "  $i) $email (active)"
    else
      echo "  $i) $email"
    fi
    ((i++))
  done

  echo ""
  printf "Switch to [1-${#accounts[@]}]: "
  read -r choice

  if [[ "$choice" -ge 1 && "$choice" -le ${#accounts[@]} ]] 2>/dev/null; then
    switch_to "${accounts[$choice]}"
  else
    echo "Invalid choice."
    return 1
  fi
}

add_account() {
  local current_email
  current_email="$(get_current_email)"

  if [[ -n "$current_email" ]]; then
    save_account "$current_email"
    echo "Saved current account: $current_email"
    echo ""
  fi

  echo "Log in with the new account in your browser."
  echo ""
  "$CLAUDE_BIN" auth login

  local new_email
  new_email="$(get_current_email)"

  if [[ -n "$new_email" ]]; then
    save_account "$new_email"
    echo ""
    echo "Added and saved: $new_email"
  else
    echo "Login failed or cancelled."
    if [[ -n "$current_email" ]]; then
      load_account "$current_email"
    fi
    return 1
  fi
}

remove_account() {
  local email="$1"

  if [[ ! -f "$ACCOUNTS_DIR/$email.json" ]]; then
    echo "No saved account for $email"
    return 1
  fi

  local current_email
  current_email="$(get_current_email)"

  if [[ "$email" == "$current_email" ]]; then
    echo "Cannot remove the active account. Switch to another account first."
    return 1
  fi

  rm -f "$ACCOUNTS_DIR/$email.json"
  echo "Removed: $email"
}

# --- Main ---
case "${1:-}" in
  switch)
    case "${2:-}" in
      add)
        add_account
        ;;
      list|ls)
        list_accounts
        ;;
      remove|rm)
        if [[ -z "${3:-}" ]]; then
          echo "Usage: claude switch remove <email>"
          exit 1
        fi
        remove_account "$3"
        ;;
      "")
        switch_interactive
        ;;
      *)
        switch_to "$2"
        ;;
    esac
    ;;

  auth|--help|-h|--version)
    exec "$CLAUDE_BIN" "$@"
    ;;

  *)
    email="$(get_current_email)"
    if [[ -n "$email" ]]; then
      echo "🔑 $email"
      echo ""
    else
      echo "⚠️  No account connected. Run: claude switch add"
      exit 1
    fi
    exec "$CLAUDE_BIN" "$@"
    ;;
esac
